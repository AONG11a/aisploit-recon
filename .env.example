# Copy to .env and fill in. NEVER commit .env.
AISPLOIT_LOG_LEVEL=INFO
AISPLOIT_LOG_JSON=true
AISPLOIT_EVIDENCE_DIR=./evidence
AISPLOIT_DB_PATH=./evidence/findings.sqlite3
AISPLOIT_EVIDENCE_RETENTION_DAYS=30

# Optional LLM judge (sends target responses to a third-party model).
AISPLOIT_JUDGE_ENABLED=false
AISPLOIT_JUDGE_MODEL=claude-sonnet-4-20250514
AISPLOIT_ANTHROPIC_API_KEY=
